{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 480,
  "maxItems": 480,
  "items": {
    "type": "object",
    "required": [
      "input",
      "output",
      "difficulty_level",
      "difficulty_param_name",
      "all_intermediate_answers",
      "operations",
      "operands",
      "seed",
      "metadata_fold"
    ],
    "additionalProperties": false,
    "properties": {
      "input": {
        "type": "string",
        "minLength": 1
      },
      "output": {
        "type": "string",
        "pattern": "^-?[0-9]+$"
      },
      "difficulty_level": {
        "type": "integer",
        "minimum": 2,
        "maximum": 25
      },
      "difficulty_param_name": {
        "type": "string",
        "const": "num_operations"
      },
      "all_intermediate_answers": {
        "type": "array",
        "items": {
          "type": "integer"
        },
        "minItems": 3
      },
      "operations": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["+", "-", "\u00d7"]
        },
        "minItems": 2
      },
      "operands": {
        "type": "array",
        "items": {
          "type": "integer"
        },
        "minItems": 2
      },
      "seed": {
        "type": "integer"
      },
      "metadata_fold": {
        "type": "string",
        "const": "test"
      }
    }
  }
}