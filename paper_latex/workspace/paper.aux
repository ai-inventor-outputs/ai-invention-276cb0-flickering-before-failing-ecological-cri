\citation{Xiong2023}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Overview of the CSD-based boundary detection framework. (a) In ecological systems, a fold bifurcation causes rising variance and flickering as the system approaches a tipping point. (b) Analogously, as task difficulty $d$ approaches an LLM's capability boundary $d^*$, the response distribution transitions from unimodal (competent) to bimodal (flickering) to unimodal (incompetent). (c) Five CSD indicators extracted from the response distribution at each difficulty level are used to classify boundary proximity.}}{5}{figure.1}\protected@file@percent }
\newlabel{fig:framework}{{1}{5}{Overview of the CSD-based boundary detection framework. (a) In ecological systems, a fold bifurcation causes rising variance and flickering as the system approaches a tipping point. (b) Analogously, as task difficulty $d$ approaches an LLM's capability boundary $d^*$, the response distribution transitions from unimodal (competent) to bimodal (flickering) to unimodal (incompetent). (c) Five CSD indicators extracted from the response distribution at each difficulty level are used to classify boundary proximity}{figure.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.6}Routing Simulation}{5}{subsection.3.6}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {4}Results}{5}{section.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}Flickering Near Capability Boundaries}{5}{subsection.4.1}\protected@file@percent }
\newlabel{sec:flickering}{{4.1}{5}{Flickering Near Capability Boundaries}{subsection.4.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces CSD indicators across difficulty levels for two representative model--task pairs. Left column: Llama-3.1-8B on arithmetic ($d^* = 20$), which exhibits flickering. Right column: Gemini-Flash on arithmetic ($d^* = 15$). Top row: accuracy (black) with 50\% threshold (dashed gray). Middle row: embedding variance (blue) and dip statistic (orange). Bottom row: disagreement rate (green). Vertical red dashed lines mark $d^*$; shaded regions indicate the boundary zone ($d^* \pm 2$). Variance and dip peak near $d^*$, while disagreement rate increases monotonically through the boundary.}}{6}{figure.2}\protected@file@percent }
\newlabel{fig:empirical_csd}{{2}{6}{CSD indicators across difficulty levels for two representative model--task pairs. Left column: Llama-3.1-8B on arithmetic ($d^* = 20$), which exhibits flickering. Right column: Gemini-Flash on arithmetic ($d^* = 15$). Top row: accuracy (black) with 50\% threshold (dashed gray). Middle row: embedding variance (blue) and dip statistic (orange). Bottom row: disagreement rate (green). Vertical red dashed lines mark $d^*$; shaded regions indicate the boundary zone ($d^* \pm 2$). Variance and dip peak near $d^*$, while disagreement rate increases monotonically through the boundary}{figure.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Boundary Classification Performance}{6}{subsection.4.2}\protected@file@percent }
\newlabel{sec:classification}{{4.2}{6}{Boundary Classification Performance}{subsection.4.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces LOPO F1 scores for boundary detection methods. The CSD-RF classifier (z-scored CSD indicators with relative distance features) achieves F1 = 0.949, outperforming the SPUQ baseline (F1 = 0.713) by 33.2\% while requiring zero additional API calls. Error bar on CSD-RF shows 95\% bootstrap confidence interval [0.940, 0.947]. Bars colored by method family: blue for CSD, red for SPUQ, gray for single-feature baselines.}}{7}{figure.3}\protected@file@percent }
\newlabel{fig:classification}{{3}{7}{LOPO F1 scores for boundary detection methods. The CSD-RF classifier (z-scored CSD indicators with relative distance features) achieves F1 = 0.949, outperforming the SPUQ baseline (F1 = 0.713) by 33.2\% while requiring zero additional API calls. Error bar on CSD-RF shows 95\% bootstrap confidence interval [0.940, 0.947]. Bars colored by method family: blue for CSD, red for SPUQ, gray for single-feature baselines}{figure.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Boundary classification F1 scores for leading methods. CSD-RF outperforms all baselines with zero API overhead. SPUQ requires 1,520 additional API calls (\$0.24).}}{7}{table.3}\protected@file@percent }
\newlabel{tab:classifier}{{3}{7}{Boundary classification F1 scores for leading methods. CSD-RF outperforms all baselines with zero API overhead. SPUQ requires 1,520 additional API calls (\$0.24)}{table.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Variance Model Fitting}{8}{subsection.4.3}\protected@file@percent }
\newlabel{sec:variance}{{4.3}{8}{Variance Model Fitting}{subsection.4.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Comparison of theoretical variance models. Left: observed embedding variance (black dots) and fitted model curves for the Gemini-Flash arithmetic series ($d^* = 15$). The mixture-switching model (blue) captures the variance peak better than the fold catastrophe model (red), which diverges unrealistically. Right: model win counts across all 10 model--task series by $R^2$. The fold catastrophe model wins 0/10 series while the mixture model wins 6/10.}}{8}{figure.4}\protected@file@percent }
\newlabel{fig:variance_models}{{4}{8}{Comparison of theoretical variance models. Left: observed embedding variance (black dots) and fitted model curves for the Gemini-Flash arithmetic series ($d^* = 15$). The mixture-switching model (blue) captures the variance peak better than the fold catastrophe model (red), which diverges unrealistically. Right: model win counts across all 10 model--task series by $R^2$. The fold catastrophe model wins 0/10 series while the mixture model wins 6/10}{figure.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Variance model comparison across 10 model--task series. The fold catastrophe model, the canonical CSD prediction, consistently fails.}}{8}{table.4}\protected@file@percent }
\newlabel{tab:models_fit}{{4}{8}{Variance model comparison across 10 model--task series. The fold catastrophe model, the canonical CSD prediction, consistently fails}{table.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Ablation: Decomposing the Predictive Signal}{9}{subsection.4.4}\protected@file@percent }
\newlabel{sec:ablation}{{4.4}{9}{Ablation: Decomposing the Predictive Signal}{subsection.4.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Ablation decomposition of classifier performance. The full model (F1 = 0.949) combines CSD indicators with difficulty-position features. CSD alone (F1 = 0.690) substantially exceeds random chance (F1 = 0.509, permutation $p = 0.01$), while difficulty position alone reaches F1 = 0.886. The unique CSD contribution is 14.3\% of the total improvement. Bottom: marginal F1 gains when individual CSD features are added to the difficulty-only baseline, with dip statistic providing the largest gain (+0.027).}}{9}{figure.5}\protected@file@percent }
\newlabel{fig:ablation}{{5}{9}{Ablation decomposition of classifier performance. The full model (F1 = 0.949) combines CSD indicators with difficulty-position features. CSD alone (F1 = 0.690) substantially exceeds random chance (F1 = 0.509, permutation $p = 0.01$), while difficulty position alone reaches F1 = 0.886. The unique CSD contribution is 14.3\% of the total improvement. Bottom: marginal F1 gains when individual CSD features are added to the difficulty-only baseline, with dip statistic providing the largest gain (+0.027)}{figure.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Ablation decomposition. Best F1 across classifier and CV combinations for each feature set. CSD provides 14.3\% unique contribution but exceeds random chance with $p = 0.01$.}}{9}{table.5}\protected@file@percent }
\newlabel{tab:ablation}{{5}{9}{Ablation decomposition. Best F1 across classifier and CV combinations for each feature set. CSD provides 14.3\% unique contribution but exceeds random chance with $p = 0.01$}{table.5}{}}
